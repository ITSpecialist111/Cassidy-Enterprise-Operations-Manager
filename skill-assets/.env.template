# Agent 365 — Environment Variables Template
# Generated by a365 config init + a365 setup all
# Copy to .env and replace placeholders

# --- Blueprint App Identity (from a365 config display -g) ---
MicrosoftAppId=<agentBlueprintId>
MicrosoftAppPassword=<agentBlueprintClientSecret>
MicrosoftAppTenantId=<tenantId>

# --- Runtime ---
# CRITICAL: Must be 'production' for Azure deployment
# Use 'development' only for local testing (disables JWT auth + binds to localhost)
NODE_ENV=production
PORT=3978

# --- Agent 365 Connection Settings (populated by a365 setup all) ---
connections__service_connection__settings__clientId=<agentBlueprintId>
agent_id=<agentBlueprintId>
connections__service_connection__settings__clientSecret=<agentBlueprintClientSecret>
connections__service_connection__settings__tenantId=<tenantId>
connections__service_connection__settings__scopes=5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default
connectionsMap__0__serviceUrl=*
connectionsMap__0__connection=service_connection
agentic_altBlueprintConnectionName=service_connection
agentic_scopes=https://graph.microsoft.com/.default
agentic_connectionName=AgenticAuthConnection

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5

# --- Work IQ MCP ---
MCP_PLATFORM_ENDPOINT=https://agent365.svc.cloud.microsoft

# --- Operations Configuration ---
OPS_TEAMS_CHANNEL_ID=<teams-channel-id>
MANAGER_EMAIL=manager@<yourtenant>.onmicrosoft.com
SCHEDULED_SECRET=<generate-a-random-secret>

# --- Organisation Context ---
ORG_NAME=Contoso Corp
ORG_INDUSTRY=Enterprise Technology
ORG_TIMEZONE=AEDT (UTC+11)
DEFAULT_TEAM_NAME=Operations

# --- Azure Speech (optional — enables voice features) ---
AZURE_SPEECH_KEY=<speech-subscription-key>
AZURE_SPEECH_REGION=australiaeast
CASSIDY_VOICE=en-AU-NatashaNeural
CASSIDY_LANGUAGE=en-AU

# --- Storage ---
AZURE_STORAGE_ACCOUNT=cassidyschedsa

# --- Planner Integration (optional — enables Planner tools) ---
PLANNER_GROUP_ID=<m365-group-id>
PLANNER_PLAN_ID=<planner-plan-id>

# --- Application Insights (optional — recommended for production) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=<InstrumentationKey=...;IngestionEndpoint=...>

# --- Proactive Engine ---
PROACTIVE_ENGINE_INTERVAL_MS=300000
PROACTIVE_COOLDOWN_MINUTES=60
PROACTIVE_BOOT_DELAY_MS=30000
BASE_URL=https://<your-webapp>.azurewebsites.net
MEETING_TRANSCRIPT_BUFFER_SIZE=50

# --- Timeout / Interval Tuning (all values in ms, defaults shown) ---
OPENAI_CLIENT_TIMEOUT_MS=120000
OPENAI_CALL_TIMEOUT_MS=90000
TOOL_EXEC_TIMEOUT_MS=30000
MCP_TOOL_TIMEOUT_MS=30000
AUTONOMOUS_POLL_INTERVAL_MS=120000
AUTONOMOUS_BOOT_DELAY_MS=15000
AUTONOMOUS_SUBTASK_TIMEOUT_MS=60000
AUTONOMOUS_BACKOFF_BASE_MS=60000
GOAL_DECOMPOSE_TIMEOUT_MS=30000
AGENT_FETCH_TIMEOUT_MS=30000
GRAPH_TIMEOUT_MS=10000
GRAPH_CACHE_TTL_MS=60000
REPORT_CACHE_TTL_MS=60000
SHUTDOWN_GRACE_PERIOD_MS=10000
